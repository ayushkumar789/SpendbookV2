# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth client id (from the old SpendBook Google Cloud Console project).
# Also paste this (plus its secret) into Supabase → Authentication → Providers → Google.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Public origin of the deployed web app — used to build share links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
